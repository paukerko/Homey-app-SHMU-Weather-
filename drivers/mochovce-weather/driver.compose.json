{
  "name": {
    "en": "Mochovce Weather"
  },
  "class": "sensor",
  "capabilities": [
    "measure_humidity",
    "measure_pressure",
    "measure_temperature",
    "measure_wind_strength",
    "measure_power"
  ],
  "platforms": ["local"],
  "connectivity": ["lan"],
  "images": {
    "small": "{{driverAssetsPath}}/images/small.png",
    "large": "{{driverAssetsPath}}/images/large.png",
    "xlarge": "{{driverAssetsPath}}/images/xlarge.png"
  },
  "pair": [
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": {
        "next": "add_devices"
      },
      "options": {
        "singular": true
      }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ]
}
